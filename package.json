{
  "name": "msalem-library",
  "version": "1.0.0",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"cd app && vite --host\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "app-build": "cd app && npm run build",
    "dist": "npm run app-build && electron-builder"
  },
  "build": {
    "appId": "com.msalem.library",
    "productName": "M'Salem Library",
    "directories": {
      "app": ".", 
      "output": "dist_installer"
    },
    "files": [
      "main/main.js",
      "main/preload.js",
      "app/dist/**/*",
      "package.json",
      "!backend/node_modules"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/server_deps",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "app/public/icon.ico",
      "forceCodeSigning": false,
      "cscLink": null,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "M'Salem Library"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "mongoose": "^8.23.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.5",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
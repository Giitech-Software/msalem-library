{
  "name": "msalem-library",
  "version": "1.0.0",
  "description": "Library Management System for M-Salem",
  "author": "M-Salem",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"cd app && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "app-build": "cd app && npm run build",
    "dist": "npm run app-build && electron-builder"
  },
  "build": {
    "appId": "com.msalem.library",
    "productName": "M'Salem Library",
    "directories": {
      "app": ".",
      "output": "dist_installer"
    },
    "files": [
      "main/**/*",
      "app/dist/**/*",
      "package.json",
      "!backend/**/*",
      "!app/node_modules/**/*",
      "!app/package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "app/public/icon.ico",
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "M'Salem Library"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "mongoose": "^8.23.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.3"
  }
}